{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/minecraft-player.schema.json",
  "title": "Minecraft Player Data Schema",
  "description": "Comprehensive schema for validating Minecraft player data with all implemented JSON Schema features.",
  "$defs": {
    "Position": {
      "type": "object",
      "properties": {
        "world": {
          "type": "string"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number",
          "minimum": -64,
          "maximum": 320
        },
        "z": {
          "type": "number"
        },
        "dimension": {
          "type": "string",
          "enum": ["minecraft:overworld", "minecraft:the_nether", "minecraft:the_end"]
        }
      },
      "required": ["world", "x", "y", "z", "dimension"],
      "additionalProperties": false
    },
    "PlayerProfile": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16
        },
        "age": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      },
      "required": ["username", "email"],
      "additionalProperties": false
    },
    "ItemStack": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^minecraft:[a-z_]+$"
        },
        "damage": {
          "type": "integer",
          "minimum": 0
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        }
      },
      "required": ["id", "damage", "count"],
      "additionalProperties": false
    },
    "InventorySlot": {
      "type": "object",
      "properties": {
        "slot": {
          "type": "integer",
          "minimum": 0,
          "maximum": 35
        },
        "item": {
          "$ref": "#/$defs/ItemStack"
        }
      },
      "required": ["slot", "item"],
      "additionalProperties": false
    },
    "PotionEffect": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^minecraft:[a-z_]+$"
        },
        "amplifier": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "duration": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["id", "amplifier", "duration"],
      "additionalProperties": false
    },
    "Attribute": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^minecraft:generic\\.[a-z_]+$"
        },
        "value": {
          "type": "number",
          "minimum": 0
        },
        "modifier": {
          "type": "number"
        }
      },
      "required": ["name", "value", "modifier"],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "playerId": {
      "type": "string",
      "pattern": "^player-[0-9]+$"
    },
    "player": {
      "$ref": "#/$defs/PlayerProfile"
    },
    "homeLocation": {
      "$ref": "#/$defs/Position"
    },
    "spawnPoint": {
      "$ref": "#/$defs/Position"
    },
    "inventory": {
      "type": "array",
      "minItems": 0,
      "maxItems": 36,
      "uniqueItems": false,
      "prefixItems": [
        {
          "$ref": "#/$defs/InventorySlot"
        }
      ],
      "items": {
        "$ref": "#/$defs/InventorySlot"
      }
    },
    "enderChest": {
      "type": "array",
      "minItems": 0,
      "maxItems": 27,
      "uniqueItems": false,
      "items": {
        "$ref": "#/$defs/InventorySlot"
      }
    },
    "balance": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01
    },
    "xpLevel": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "gameMode": {
      "type": "string",
      "enum": ["survival", "creative", "adventure", "spectator"]
    },
    "health": {
      "type": "number",
      "minimum": 0,
      "exclusiveMaximum": 1000
    },
    "foodLevel": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20
    },
    "joinedAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastSeen": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "statistics": {
      "type": "object",
      "properties": {
        "blocksMined": {
          "type": "integer",
          "minimum": 0
        },
        "entitiesKilled": {
          "type": "integer",
          "minimum": 0
        },
        "itemsCrafted": {
          "type": "integer",
          "minimum": 0
        },
        "distanceTravelled": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": ["blocksMined"],
      "minProperties": 1,
      "maxProperties": 10,
      "additionalProperties": {
        "type": ["integer", "number"]
      }
    },
    "effects": {
      "type": "array",
      "minItems": 0,
      "maxItems": 32,
      "uniqueItems": false,
      "items": {
        "$ref": "#/$defs/PotionEffect"
      }
    },
    "attributes": {
      "type": "array",
      "minItems": 0,
      "maxItems": 20,
      "uniqueItems": false,
      "items": {
        "$ref": "#/$defs/Attribute"
      }
    },
    "recipes": {
      "type": "array",
      "minItems": 0,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^minecraft:[a-z_]+$"
          },
          "count": {
            "type": "integer",
            "minimum": 1
          }
        },
        "required": ["id", "count"],
        "additionalProperties": false
      }
    },
    "advancements": {
      "type": "array",
      "minItems": 0,
      "maxItems": 200,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^minecraft:[a-z/]+$"
      }
    },
    "tags": {
      "type": "array",
      "minItems": 0,
      "maxItems": 50,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^#minecraft:[a-z_]+$"
      }
    },
    "party": {
      "type": ["object", "null"],
      "properties": {
        "leader": {
          "type": "string"
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["leader", "members"],
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "properties": {
        "isOp": {
          "type": "boolean"
        },
        "isFlying": {
          "type": "boolean"
        },
        "canBuild": {
          "type": "boolean"
        }
      },
      "minProperties": 1,
      "maxProperties": 5,
      "additionalProperties": {
        "type": "boolean"
      }
    }
  },
  "required": [
    "playerId",
    "player",
    "gameMode"
  ],
  "minProperties": 3,
  "maxProperties": 30,
  "anyOf": [
    {
      "properties": {
        "gameMode": {
          "enum": ["survival", "adventure"]
        }
      },
      "required": ["health", "foodLevel"]
    },
    {
      "properties": {
        "gameMode": {
          "enum": ["creative", "spectator"]
        }
      }
    }
  ],
  "if": {
    "properties": {
      "gameMode": {
        "enum": ["survival"]
      }
    }
  },
  "then": {
    "properties": {
      "health": {
        "type": "number",
        "minimum": 0
      }
    },
    "required": ["health", "foodLevel", "inventory"]
  },
  "additionalProperties": false
}
