{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Conditional Player Validation",
  "description": "Demonstrates oneOf, not, and if/then/else conditional validation",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "playerType": {
      "type": "string",
      "enum": ["warrior", "mage", "rogue", "healer", "merchant", "quest-giver"]
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 32
    },
    "level": {
      "type": "number"
    },
    "stats": {
      "type": "object"
    },
    "inventory": {
      "type": "object"
    },
    "guild": {
      "type": "string"
    }
  },
  "oneOf": [
    {
      "additionalProperties": false,
      "properties": {
        "playerType": {
          "const": "warrior"
        },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "required": ["strength", "defense"],
          "properties": {
            "strength": {
              "type": "number",
              "minimum": 10,
              "maximum": 100
            },
            "defense": {
              "type": "number",
              "minimum": 5,
              "maximum": 80
            }
          }
        }
      },
      "required": ["playerType", "name", "stats"]
    },
    {
      "additionalProperties": false,
      "properties": {
        "playerType": {
          "const": "mage"
        },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "required": ["intelligence", "mana"],
          "properties": {
            "intelligence": {
              "type": "number",
              "minimum": 15,
              "maximum": 100
            },
            "mana": {
              "type": "number",
              "minimum": 50,
              "maximum": 500
            }
          }
        }
      },
      "required": ["playerType", "name", "stats"]
    },
    {
      "additionalProperties": false,
      "properties": {
        "playerType": {
          "const": "rogue"
        },
        "stats": {
          "type": "object",
          "additionalProperties": false,
          "required": ["agility", "stealth"],
          "properties": {
            "agility": {
              "type": "number",
              "minimum": 15,
              "maximum": 100
            },
            "stealth": {
              "type": "number",
              "minimum": 10,
              "maximum": 100
            }
          }
        }
      },
      "required": ["playerType", "name", "stats"]
    }
  ],
  "not": {
    "properties": {
      "playerType": {
        "const": "banned"
      }
    }
  },
  "if": {
    "properties": {
      "playerType": {
        "enum": ["warrior", "mage", "rogue", "healer"]
      }
    },
    "required": ["level"]
  },
  "then": {
    "properties": {
      "level": {
        "type": "number",
        "minimum": 1,
        "maximum": 100
      }
    }
  },
  "else": {
    "properties": {
      "level": {
        "type": "number",
        "minimum": 0,
        "maximum": 10
      }
    }
  }
}