{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Player Schema",
  "description": "Basic player data validation schema for production use",
  "type": "object",
  "required": ["name", "level"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 32
    },
    "level": {
      "type": "number",
      "minimum": 1,
      "maximum": 100
    },
    "health": {
      "type": "number",
      "minimum": 0,
      "maximum": 1000
    },
    "class": {
      "type": "string",
      "enum": ["warrior", "mage", "rogue", "healer"]
    },
    "guild": {
      "type": "string"
    }
  }
}
