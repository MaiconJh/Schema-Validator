# ============================================
# ARQUIVOS DE BUILD E COMPILAÇÃO
# ============================================
# Diretórios gerados durante a compilação do projeto

# Build do Gradle/Maven
build/
target/

# Saída de compilação do IntelliJ IDEA
out/

# Arquivos de classe Java
*.class

# Arquivos JAR packaging
*.jar
*.war
*.ear
*.ear

# Arquivos de dependências (libs locais)
lib/
libs/

# Output de compilação Eclipse
bin/


# ============================================
# ARQUIVOS DO GRADLE
# ============================================
# Arquivos e diretórios relacionados ao Gradle

#agentes
*.kilo

# Cache do Kilo
.kilo/

# Wrapper do Gradle (não precisa ser versionado)
gradle/wrapper/

# Cache do Gradle
.gradle/

# Build do Gradle (pode variar dependendo da configuração)
!gradle/wrapper/gradle-wrapper.jar

# Cache de tarefas do Gradle
.gradle/

# Output do Gradle
build/


