# ============================================
# EXCEÇÕES IMPORTANTES
# ============================================
# Exceções para arquivos que DEVEM ser versionados

# Este arquivo deve ser versionado
!.gitignore

# O arquivo de wrapper do Gradle deve ser versionado
!gradle/wrapper/gradle-wrapper.jar

# O arquivo de build do Gradle pode ser necessário
build.gradle
build.gradle.kts
settings.gradle
settings.gradle.kts

# O diretório src deve ser versionado
!src/

# O diretório resources deve ser versionado
!resources/

# Documentação do projeto
!README.md
!LICENSE

